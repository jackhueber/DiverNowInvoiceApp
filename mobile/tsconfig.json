{
  "compilerOptions": {
    "allowJs": false,
    "jsx": "react-jsx",
    "lib": ["DOM", "ESNext"],
    "moduleResolution": "node",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "types": ["react", "react-native", "react-dom"]
  },
  "extends": "expo/tsconfig.base",
  "include": [
    "App.tsx",
    "src"
  ]
}
